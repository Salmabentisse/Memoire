          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Statut HTTP 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Temps de réponse inférieur à 30 secondes', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(30000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
